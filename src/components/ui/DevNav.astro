---
// TEMPORARY DEV NAVIGATION — remove before production
const mainPages = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "SIRS Experience", href: "/sirs-experience" },
  { label: "Admissions", href: "/admissions" },
  { label: "Contact", href: "/contact-us" },
];

const consumptionPages = [
  { label: "Blogs Listing", href: "/media/blogs" },
  { label: "Blog Detail", href: "/media/blogs/test-blog" },
  { label: "Albums Listing", href: "/media/albums" },
  { label: "Awards Listing", href: "/awards" },
  { label: "Facilities Detail", href: "/campus/hostel-life" },
  { label: "Global SAIoneers", href: "/sirs-experience/global-saIoneers" },
  { label: "Vision/Mission", href: "/about/vision" },
  { label: "Admission Guidelines", href: "/admissions/guidelines" },
];

const current = Astro.url.pathname;
---

<div class="fixed top-4 right-4 z-[999] font-secondary">
  <details class="group">
    <summary
      class="cursor-pointer rounded-lg bg-violet-700 px-4 py-2 text-sm font-semibold text-white list-none"
    >
      🧭 Dev Nav
    </summary>

    <div
      class="absolute top-10 right-0 w-56 rounded-xl border border-n-200 bg-white shadow-xl overflow-hidden"
    >
      <!-- Main Pages -->
      <p class="bg-n-100 px-3 py-1.5 text-xs font-semibold text-n-500 uppercase tracking-wider">
        Main Pages
      </p>
      {
        mainPages.map((page) => (
          <a
            href={page.href}
            class={`block px-3 py-2 text-sm transition hover:bg-orange-50 hover:text-orange-500 ${current === page.href ? "bg-orange-50 text-orange-500 font-semibold" : "text-n-700"}`}
          >
            {page.label}
          </a>
        ))
      }

      <!-- Consumption Pages -->
      <p class="bg-n-100 px-3 py-1.5 text-xs font-semibold text-n-500 uppercase tracking-wider border-t border-n-200">
        Consumption Pages
      </p>
      {
        consumptionPages.map((page) => (
          <a
            href={page.href}
            class={`block px-3 py-2 text-sm transition hover:bg-orange-50 hover:text-orange-500 ${current === page.href ? "bg-orange-50 text-orange-500 font-semibold" : "text-n-700"}`}
          >
            {page.label}
          </a>
        ))
      }
    </div>
  </details>
</div>
