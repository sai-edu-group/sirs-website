    copy: "A climbing wall up the school building itself.",
    photo: "Photo — climbing wall, low angle",
    size: "small",
    accent: "slate",
  },
  {
    title: "A lake for boating",
    copy: "Calm water, life jackets, loud laughter.",
    photo: "Photo — boating on the lake",
    size: "small",
    accent: "slate",
  },
  {
    title: "Swimming pool",
    copy: "Coached training, all levels.",
    photo: "Photo — swim training",
    size: "small",
    accent: "orange",
  },
  {
    title: "Music rooms",
    copy: "Drums, piano, tabla, guitar & more.",
    photo: "Photo — music class",
    size: "small",
    accent: "violet",
  },
  {
    title: "Indoor sports arena",
    copy: "Basketball, badminton, yoga & rainy-day energy.",
    photo: "Photo — indoor arena",
    size: "wide",
    accent: "orange",
  },
];

// ---- 06 · Flagship events marquee --------------------------
const events = [
  "SAI Olympics",
  "SAI Football League",
  "SAI Kaleidoscope",
  "SAIMUN",
  "SAI TED",
  "SAI Champions Trophy",
  "Founder's Day",
  "SAI Unwind",
];

// ---- 08 · Second home --------------------------------------
const homeCards = [
  {
    title: "Arjuna Boys' Hostel",
    copy: "Air-conditioned rooms, recreational lounges and house masters who know every child by name.",
    photo: "Photo — hostel room / lounge",
  },
  {
    title: "Sushila Devi Girls' Hostel",
    copy: "Safe, warm and watched over — with wardens, tight security and space to be yourself.",
    photo: "Photo — girls' hostel common area",
  },
  {
    title: "Meals made with care",
    copy: "Nutritionist-supervised menus from our own cafeteria — because growing minds need growing bodies.",
    photo: "Photo — cafeteria mealtime",
  },
  {
    title: "Always looked after",
    copy: "On-campus infirmary, the serene SAI Temple, and evening yoga to end the day quietly.",
    photo: "Photo — yoga at dusk",
  },
];

const houses = [
  { name: "Dhvaja", classes: "bg-orange-100 text-orange-700" },
  { name: "Srivatsa", classes: "bg-violet-100 text-violet-600" },
  { name: "Vajra", classes: "bg-n-100 text-n-700" },
  { name: "Chakra", classes: "bg-orange-50 text-orange-600" },
];

// ---- 10 · Beyond school ------------------------------------
const beyond = [
