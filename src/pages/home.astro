// ============================================================
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/ui/Button.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import IconsCard from "@/components/ui/IconsCard.astro";

// ---- 02 · The 8-8-8 band -----------------------------------
const eights = [
